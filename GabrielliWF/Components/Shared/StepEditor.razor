@inject TemplateService TemplateService
@inject FactoryLookupService Factory

<MudPaper Elevation="1" Class="pa-3">
    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Step del Workflow</b></MudText>

    @if (Steps.Count == 0)
    {
        <MudAlert Severity="Severity.Info">Nessuno step aggiunto. Aggiungi gli step qui sotto.</MudAlert>
    }

    <MudList T="WorkflowStepModel" Dense="true" Class="mb-2">
        @foreach (var (step, idx) in Steps.Select((s, i) => (s, i)))
        {
            <MudListItem>
                <div class="d-flex align-center gap-2" style="width:100%">
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">@(idx + 1)</MudChip>
                    <div class="flex-grow-1">
                        <MudText Typo="Typo.body2"><b>@step.NomeStep</b></MudText>
                        @if (!string.IsNullOrEmpty(step.NomeAttributo))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Attributo: @step.NomeAttributo</MudText>
                        }
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                        Disabled="idx == 0" OnClick="@(() => MoveUp(idx))" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                        Disabled="idx == Steps.Count - 1" OnClick="@(() => MoveDown(idx))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                        OnClick="@(() => Remove(idx))" />
                </div>
            </MudListItem>
        }
    </MudList>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.subtitle2" Class="mb-2">Aggiungi step</MudText>
    <MudGrid Spacing="2">

        <!-- Campo 1: ricerca nel catalogo -->
        <MudItem xs="12" md="4">
            <MudAutocomplete T="WfStepDef"
                Label="Cerca nel catalogo (opzionale)"
                Value="_stepCatalogo"
                ValueChanged="OnStepCatalogoChanged"
                SearchFunc="SearchStepDefsAsync"
                ToStringFunc="@(s => s?.Nome ?? "")"
                MinCharacters="0"
                Clearable="true"
                Variant="Variant.Outlined"
                Placeholder="Cerca step esistente...">
                <NoItemsTemplate>
                    <MudText Typo="Typo.caption" Class="px-4 py-2">Nessuno nel catalogo</MudText>
                </NoItemsTemplate>
            </MudAutocomplete>
        </MudItem>

        <!-- Campo 2: nome step (precompilato da catalogo oppure scritto liberamente) -->
        <MudItem xs="12" md="3">
            <MudTextField T="string"
                Label="Nome step *"
                @bind-Value="_nomeStep"
                Variant="Variant.Outlined"
                Placeholder="Scrivi il nome..."
                HelperText="@(_stepCatalogo is not null ? "Dal catalogo" : "Nuovo step (verrà creato)")" />
        </MudItem>

        <!-- Campo 3: attributo -->
        <MudItem xs="12" md="3">
            <MudSelect T="AttributoDto?"
                Label="Attributo (opz.)"
                @bind-Value="_attributoSelezionato"
                ToStringFunc="@(a => a?.Descrizione ?? "")"
                Variant="Variant.Outlined"
                Clearable="true"
                AnchorOrigin="Origin.BottomLeft">
                <MudSelectItem Value="(AttributoDto?)null">— Nessuno —</MudSelectItem>
                @foreach (var a in _attributi)
                {
                    <MudSelectItem Value="(AttributoDto?)a">@a.Descrizione</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <!-- Pulsante -->
        <MudItem xs="12" md="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                StartIcon="@Icons.Material.Filled.Add" OnClick="AddStep"
                Disabled="@string.IsNullOrWhiteSpace(_nomeStep)">
                Aggiungi
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter] public List<WorkflowStepModel> Steps { get; set; } = [];
    [Parameter] public EventCallback<List<WorkflowStepModel>> StepsChanged { get; set; }

    private WfStepDef? _stepCatalogo;
    private string _nomeStep = string.Empty;
    private AttributoDto? _attributoSelezionato;
    private List<AttributoDto> _attributi = [];

    protected override async Task OnInitializedAsync()
    {
        _attributi = await Factory.GetAttributiAsync();
    }

    private async Task<IEnumerable<WfStepDef>> SearchStepDefsAsync(string filter, CancellationToken ct)
    {
        return await TemplateService.GetStepDefsAsync(string.IsNullOrWhiteSpace(filter) ? null : filter);
    }

    private void OnStepCatalogoChanged(WfStepDef? val)
    {
        _stepCatalogo = val;
        // pre-compila il nome dal catalogo; se si deseleziona lascia il campo libero
        if (val is not null)
            _nomeStep = val.Nome;
    }

    private async Task AddStep()
    {
        var nome = _nomeStep.Trim();
        if (string.IsNullOrWhiteSpace(nome)) return;

        Steps.Add(new WorkflowStepModel
        {
            Ordine     = Steps.Count + 1,
            IDStepDef  = _stepCatalogo?.ID,
            NomeStep   = nome,
            IDAttributo    = _attributoSelezionato?.Id,
            NomeAttributo  = _attributoSelezionato?.Descrizione
        });
        await StepsChanged.InvokeAsync(Steps);

        _stepCatalogo        = null;
        _nomeStep            = string.Empty;
        _attributoSelezionato = null;
    }

    private async Task Remove(int idx)
    {
        Steps.RemoveAt(idx);
        RenumberSteps();
        await StepsChanged.InvokeAsync(Steps);
    }

    private async Task MoveUp(int idx)
    {
        (Steps[idx - 1], Steps[idx]) = (Steps[idx], Steps[idx - 1]);
        RenumberSteps();
        await StepsChanged.InvokeAsync(Steps);
    }

    private async Task MoveDown(int idx)
    {
        (Steps[idx], Steps[idx + 1]) = (Steps[idx + 1], Steps[idx]);
        RenumberSteps();
        await StepsChanged.InvokeAsync(Steps);
    }

    private void RenumberSteps()
    {
        for (int i = 0; i < Steps.Count; i++) Steps[i].Ordine = i + 1;
    }
}
