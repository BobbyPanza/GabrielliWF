@inject TemplateService TemplateService
@inject FactoryLookupService Factory

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">Aggiungi Step</MudText></TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudAutocomplete T="WfStepDef?"
                    Label="Step da catalogo (o inserisci nuovo)"
                    @bind-Value="_stepDef"
                    SearchFunc="SearchAsync"
                    ToStringFunc="@(s => s?.Nome ?? "")"
                    MinCharacters="0"
                    Clearable="true"
                    Variant="Variant.Outlined"
                    Dense="true"
                    ResetValueOnEmptyText="false"
                    CoerceText="true"
                    TextChanged="OnTextChanged" />
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="AttributoDto?"
                    Label="Attributo (opzionale)"
                    @bind-Value="_attributo"
                    ToStringFunc="@(a => a?.Descrizione ?? "")"
                    Variant="Variant.Outlined" Dense="true" Clearable="true"
                    AnchorOrigin="Origin.BottomLeft">
                    <MudSelectItem Value="(AttributoDto?)null">— Nessuno —</MudSelectItem>
                    @foreach (var a in _attributi)
                    {
                        <MudSelectItem Value="(AttributoDto?)a">@a.Descrizione</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annulla</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit"
            Disabled="string.IsNullOrWhiteSpace(_nomeStep)">Aggiungi</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private WfStepDef? _stepDef;
    private AttributoDto? _attributo;
    private string _nomeStep = string.Empty;
    private List<AttributoDto> _attributi = [];

    protected override async Task OnInitializedAsync()
    {
        _attributi = await Factory.GetAttributiAsync();
    }

    private async Task<IEnumerable<WfStepDef?>> SearchAsync(string filter, CancellationToken ct) =>
        (await TemplateService.GetStepDefsAsync(string.IsNullOrWhiteSpace(filter) ? null : filter))
        .Cast<WfStepDef?>();

    private void OnTextChanged(string text)
    {
        _nomeStep = text ?? string.Empty;
        if (_stepDef?.Nome != text) _stepDef = null;
    }

    private void Submit()
    {
        var step = new WorkflowStepModel
        {
            IDStepDef = _stepDef?.ID,
            NomeStep = _stepDef?.Nome ?? _nomeStep.Trim(),
            IDAttributo = _attributo?.Id,
            NomeAttributo = _attributo?.Descrizione
        };
        MudDialog.Close(DialogResult.Ok(step));
    }

    private void Cancel() => MudDialog.Cancel();
}
