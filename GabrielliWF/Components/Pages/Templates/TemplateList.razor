@page "/templates"
@inject TemplateService TemplateService
@inject ISnackbar Snackbar
@inject IDialogService Dialog

<PageTitle>Template Workflow</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-3">
    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Class="mr-1" Style="vertical-align:middle" />Template Workflow
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">@_templates.Count template salvati</MudText>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_templates.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            Nessun template salvato. I template vengono creati durante la creazione di un nuovo impegno.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var tpl in _templates)
            {
                <MudItem xs="12" md="6" lg="4">
                    <div class="tpl-card">
                        <!-- Header -->
                        <div class="tpl-header">
                            <div class="tpl-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree"
                                    Style="font-size:1.1rem; color:#5c6bc0" />
                            </div>
                            <div class="tpl-title-area">
                                <span class="tpl-name">@tpl.Nome</span>
                                <span class="tpl-date">
                                    @tpl.DataCreazione.ToString("dd/MM/yyyy")
                                    @if (!string.IsNullOrEmpty(tpl.CreatoDa))
                                    { <text> · @tpl.CreatoDa</text> }
                                </span>
                            </div>
                            <MudTooltip Text="Archivia template" Placement="Placement.Left">
                                <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                                    Size="Size.Small" Color="Color.Error"
                                    OnClick="@(() => ArchiviaTemplate(tpl.ID))" />
                            </MudTooltip>
                        </div>

                        <!-- Elenco step -->
                        @if (tpl.Steps.Any())
                        {
                            <div class="tpl-steps">
                                @foreach (var s in tpl.Steps.OrderBy(x => x.Ordine))
                                {
                                    var nome = s.StepDef?.Nome ?? s.NomeCustom ?? $"Step {s.Ordine}";
                                    <div class="tpl-step">
                                        <span class="tpl-step-num">@s.Ordine</span>
                                        <span class="tpl-step-name">@nome</span>
                                        @if (s.IDAttributo.HasValue)
                                        {
                                            <MudTooltip Text="Con attributo qualità">
                                                <span class="tpl-step-attr">◆</span>
                                            </MudTooltip>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        <!-- Footer -->
                        <div class="tpl-footer">
                            <span class="tpl-count">
                                <MudIcon Icon="@Icons.Material.Filled.ListAlt"
                                    Style="font-size:0.85rem; vertical-align:middle; margin-right:3px" />
                                @tpl.Steps.Count @(tpl.Steps.Count == 1 ? "step" : "step")
                            </span>
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<style>
    .tpl-card {
        background: var(--mud-palette-surface);
        border: 1px solid rgba(0,0,0,0.08);
        border-top: 3px solid #5c6bc0;
        border-radius: 8px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: box-shadow 0.15s, transform 0.12s;
        height: 100%;
    }
    .tpl-card:hover {
        box-shadow: 0 4px 16px rgba(92,107,192,0.14);
        transform: translateY(-1px);
    }
    /* Header */
    .tpl-header {
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }
    .tpl-icon-box {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: #ede7f6;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .tpl-title-area {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }
    .tpl-name {
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--mud-palette-text-primary);
        line-height: 1.3;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .tpl-date { font-size: 0.73rem; color: #aaa; }
    /* Step list */
    .tpl-steps {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }
    .tpl-step {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.81rem;
        padding: 4px 6px;
        border-radius: 4px;
        transition: background 0.1s;
    }
    .tpl-step:hover { background: rgba(92,107,192,0.05); }
    .tpl-step-num {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #ede7f6;
        color: #5c6bc0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.7rem;
        flex-shrink: 0;
    }
    .tpl-step-name {
        flex: 1;
        color: var(--mud-palette-text-primary);
    }
    .tpl-step-attr {
        color: #fb8c00;
        font-size: 0.65rem;
        flex-shrink: 0;
    }
    /* Footer */
    .tpl-footer {
        border-top: 1px solid rgba(0,0,0,0.06);
        padding-top: 8px;
        display: flex;
        align-items: center;
    }
    .tpl-count {
        font-size: 0.75rem;
        color: #7986cb;
        font-weight: 600;
    }
</style>

@code {
    private List<WfTemplate> _templates = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _templates = await TemplateService.GetAllAsync();
        foreach (var t in _templates)
        {
            var full = await TemplateService.GetByIdAsync(t.ID);
            if (full is not null) t.Steps = full.Steps;
        }
        _loading = false;
    }

    private async Task ArchiviaTemplate(int id)
    {
        var confirm = await Dialog.ShowMessageBox(
            "Conferma archiviazione",
            "Archiviare questo template? Non sarà più disponibile per nuovi impegni.",
            "Archivia", cancelText: "Annulla");
        if (confirm != true) return;
        await TemplateService.MarkObsoleteAsync(id);
        _templates = await TemplateService.GetAllAsync();
        foreach (var t in _templates) { var full = await TemplateService.GetByIdAsync(t.ID); if (full is not null) t.Steps = full.Steps; }
        Snackbar.Add("Template archiviato", Severity.Success);
    }
}
