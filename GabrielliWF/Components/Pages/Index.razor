@page "/"
@inject ImpegnoService ImpegnoService
@inject AppDbContext Db
@inject NavigationManager Nav

<PageTitle>Monitoraggio Impegni</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-3">
    <div class="d-flex justify-space-between align-center mb-2">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-1" />Monitoraggio Impegni
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
            StartIcon="@Icons.Material.Filled.Add" Href="/impegni/nuovo">
            Nuovo Impegno
        </MudButton>
    </div>

    <!-- Barra filtri -->
    <MudPaper Elevation="1" Class="pa-2 mb-2">
        <div class="d-flex flex-wrap align-center gap-1 mb-2">
            <MudText Typo="Typo.caption" Class="mr-1">Stato:</MudText>
            <MudChip T="bool" Size="Size.Small" Color="Color.Primary"
                OnClick="@(() => _filtroStato = null)"
                Variant="@(_filtroStato == null ? Variant.Filled : Variant.Outlined)">Tutti</MudChip>
            <MudChip T="bool" Size="Size.Small" Color="Color.Primary"
                OnClick="@(() => _filtroStato = StatoImpegno.Aperto)"
                Variant="@(_filtroStato == StatoImpegno.Aperto ? Variant.Filled : Variant.Outlined)">Aperti</MudChip>
            <MudChip T="bool" Size="Size.Small" Color="Color.Success"
                OnClick="@(() => _filtroStato = StatoImpegno.Completato)"
                Variant="@(_filtroStato == StatoImpegno.Completato ? Variant.Filled : Variant.Outlined)">Completati</MudChip>
            <MudChip T="bool" Size="Size.Small" Color="Color.Default"
                OnClick="@(() => _filtroStato = StatoImpegno.Annullato)"
                Variant="@(_filtroStato == StatoImpegno.Annullato ? Variant.Filled : Variant.Outlined)">Annullati</MudChip>
            <MudSpacer />
            <MudText Typo="Typo.caption" Color="Color.Secondary">@ImpegniFiltrati.Count() record</MudText>
        </div>
        <MudGrid Spacing="1">
            <MudItem xs="6" sm="4" md="2">
                <MudTextField T="string" @bind-Value="_filtroLotto" Label="Lotto / Articolo"
                    Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                    Immediate="true" DebounceInterval="200" />
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudTextField T="string" @bind-Value="_filtroCliente" Label="Cliente"
                    Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                    Immediate="true" DebounceInterval="200" />
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudTextField T="string" @bind-Value="_filtroCommessa" Label="Commessa"
                    Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                    Immediate="true" DebounceInterval="200" />
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudSelect T="string?" @bind-Value="_filtroQualita" Label="Qualità"
                    Variant="Variant.Outlined" Margin="Margin.Dense"
                    Clearable="true" AnchorOrigin="Origin.BottomLeft">
                    <MudSelectItem Value="(string?)null">— Tutte —</MudSelectItem>
                    @foreach (var q in _qualitaDisponibili)
                    {
                        <MudSelectItem Value="(string?)q">@q</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudTextField T="string" @bind-Value="_filtroSpessore" Label="Spessore"
                    Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                    Immediate="true" DebounceInterval="200"
                    HelperText="Cerca in descrizione art." />
            </MudItem>
            <MudItem xs="6" sm="4" md="2" Class="d-flex align-center">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small"
                    StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ResetFiltri">
                    Reset
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!ImpegniFiltrati.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-2">Nessun impegno trovato con i filtri attivi.</MudAlert>
    }
    else
    {
        <div class="imp-scroll-area">
            @foreach (var imp in ImpegniFiltrati)
            {
                <div class="imp-card @GetCardClass(imp.Stato)"
                     @onclick="@(() => Nav.NavigateTo($"/impegni/{imp.ID}"))">
                    <div class="imp-info">
                        <span class="imp-lotto">@imp.CrCod</span>
                        <span class="imp-mat">
                            <span class="imp-mat-cod">@imp.PaCod</span>
                            @if (!string.IsNullOrEmpty(imp.PaDsc))
                            {
                                <span class="imp-mat-dsc">&nbsp;@(imp.PaDsc.Length > 50 ? imp.PaDsc[..50] + "…" : imp.PaDsc)</span>
                            }
                        </span>
                        @if (!string.IsNullOrEmpty(imp.JdeQuality))
                        {
                            <span class="imp-qual">@imp.JdeQuality</span>
                        }
                        @if (imp.Riferimenti.Any())
                        {
                            <span class="imp-ref">
                                @string.Join(" · ", imp.Riferimenti
                                    .Select(r => r.CtRag).Where(x => !string.IsNullOrEmpty(x)).Distinct().Take(2))
                                @{
                                    var commesse = imp.Riferimenti
                                        .Select(r => r.CoCod).Where(x => !string.IsNullOrEmpty(x)).Distinct().Take(2).ToList();
                                }
                                @if (commesse.Any())
                                {
                                    <span class="imp-commessa">&nbsp;/ @string.Join(", ", commesse)</span>
                                }
                            </span>
                        }
                        <span class="imp-spacer"></span>
                        <span class="imp-data">@imp.DataImpegno.ToString("dd/MM/yy")</span>
                        <span class="imp-stato imp-stato-@imp.Stato.ToString().ToLower()">@imp.Stato</span>
                    </div>
                    @if (_workflowChains.TryGetValue(imp.ID, out var wfList) && wfList.Any())
                    {
                        <div class="imp-chain">
                            @foreach (var wf in wfList)
                            {
                                <WorkflowChain Steps="wf.Steps.OrderBy(s => s.Ordine).ToList()" />
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</MudContainer>

<style>
    .imp-scroll-area {
        overflow-y: auto;
        max-height: calc(100vh - 300px);
        padding-right: 3px;
    }
    .imp-card {
        background: var(--mud-palette-surface);
        border: 1px solid rgba(0,0,0,0.07);
        border-left: 4px solid #1976d2;
        border-radius: 6px;
        padding: 8px 14px 6px;
        margin-bottom: 5px;
        cursor: pointer;
        transition: box-shadow 0.15s, transform 0.12s, border-left-color 0.15s;
    }
    .imp-card:hover {
        box-shadow: 0 3px 12px rgba(0,0,0,0.10);
        transform: translateX(2px);
    }
    .imp-card-completato { border-left-color: #43a047; }
    .imp-card-annullato  { border-left-color: #bdbdbd; opacity: 0.65; }
    .imp-info {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        font-size: 0.82rem;
        line-height: 1.5;
    }
    .imp-lotto {
        font-weight: 700;
        font-size: 0.86rem;
        color: #1565c0;
        white-space: nowrap;
        min-width: 82px;
        letter-spacing: 0.01em;
    }
    .imp-mat        { flex: 1; min-width: 130px; }
    .imp-mat-cod    { font-weight: 600; color: var(--mud-palette-text-primary); }
    .imp-mat-dsc    { color: var(--mud-palette-text-secondary); font-size: 0.79rem; }
    .imp-qual {
        background: #e8eaf6;
        color: #3949ab;
        border-radius: 10px;
        padding: 2px 9px;
        font-size: 0.71rem;
        font-weight: 700;
        white-space: nowrap;
        letter-spacing: 0.03em;
    }
    .imp-ref      { color: var(--mud-palette-text-secondary); font-size: 0.78rem; }
    .imp-commessa { color: #1976d2; font-weight: 500; }
    .imp-spacer   { flex: 1; }
    .imp-data     { color: #aaa; font-size: 0.74rem; white-space: nowrap; }
    .imp-stato    { border-radius: 10px; padding: 2px 10px; font-size: 0.71rem; font-weight: 700; white-space: nowrap; letter-spacing: 0.02em; }
    .imp-stato-aperto     { background: #e3f2fd; color: #1565c0; }
    .imp-stato-completato { background: #e8f5e9; color: #2e7d32; }
    .imp-stato-annullato  { background: #f5f5f5; color: #9e9e9e; }
    .imp-chain {
        padding: 5px 2px 3px;
        border-top: 1px solid rgba(0,0,0,0.06);
        margin-top: 5px;
    }
</style>

@code {
    private List<ImpegnoListItem> _impegni = [];
    private Dictionary<int, List<WfWorkflow>> _workflowChains = [];
    private bool _loading = true;

    private StatoImpegno? _filtroStato = StatoImpegno.Aperto;
    private string? _filtroLotto;
    private string? _filtroCliente;
    private string? _filtroCommessa;
    private string? _filtroQualita;
    private string? _filtroSpessore;
    private List<string> _qualitaDisponibili = [];

    private IEnumerable<ImpegnoListItem> ImpegniFiltrati =>
        _impegni.Where(i =>
            (_filtroStato == null || i.Stato == _filtroStato)
            && (string.IsNullOrEmpty(_filtroLotto) ||
                i.CrCod.Contains(_filtroLotto, StringComparison.OrdinalIgnoreCase) ||
                (i.PaCod?.Contains(_filtroLotto, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (i.PaDsc?.Contains(_filtroLotto, StringComparison.OrdinalIgnoreCase) ?? false))
            && (string.IsNullOrEmpty(_filtroCliente) ||
                i.Riferimenti.Any(r => r.CtRag?.Contains(_filtroCliente, StringComparison.OrdinalIgnoreCase) ?? false))
            && (string.IsNullOrEmpty(_filtroCommessa) ||
                i.Riferimenti.Any(r => r.CoCod?.Contains(_filtroCommessa, StringComparison.OrdinalIgnoreCase) ?? false))
            && (string.IsNullOrEmpty(_filtroQualita) || i.JdeQuality == _filtroQualita)
            && (string.IsNullOrEmpty(_filtroSpessore) ||
                (i.PaDsc?.Contains(_filtroSpessore, StringComparison.OrdinalIgnoreCase) ?? false)));

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _impegni = await ImpegnoService.GetListAsync();
        _workflowChains = Db.Workflows
            .Include(w => w.Steps).ThenInclude(s => s.StepDef)
            .AsEnumerable()
            .GroupBy(w => w.IDImpegno)
            .ToDictionary(g => g.Key, g => g.ToList());
        _qualitaDisponibili = _impegni
            .Where(i => !string.IsNullOrEmpty(i.JdeQuality))
            .Select(i => i.JdeQuality!)
            .Distinct().OrderBy(q => q).ToList();
        _loading = false;
    }

    private void ResetFiltri()
    {
        _filtroStato = null; _filtroLotto = null; _filtroCliente = null;
        _filtroCommessa = null; _filtroQualita = null; _filtroSpessore = null;
    }

    private static string GetCardClass(StatoImpegno stato) => stato switch
    {
        StatoImpegno.Completato => "imp-card-completato",
        StatoImpegno.Annullato  => "imp-card-annullato",
        _                       => ""
    };
}
